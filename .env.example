OPENAI_API_KEY=your_openai_api_key
QDRANT_URL=http://qdrant:6333
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
SECRET_KEY=replace_with_random_secret_key
QDRANT_COLLECTION=ai_research_chunks
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4.1-mini
BACKEND_URL=http://backend:8000

# Optional: ingestion / chunking (defaults work for smoke loads; tune when scaling)
# ARXIV_PAGE_SIZE=100
# ARXIV_INTER_REQUEST_DELAY_SECONDS=3.0
# INGEST_MIN_DOCUMENT_CHARS=200
# INGEST_MIN_CHUNK_CHARS=40
# CHUNK_SIZE=900
# CHUNK_OVERLAP=150
# EMBEDDING_BATCH_SIZE=64
# QDRANT_UPSERT_BATCH_SIZE=128

# Retrieval tuning (optional)
# RETRIEVAL_PREFETCH_MULTIPLIER=8
# RETRIEVAL_RRF_K=60
# RETRIEVAL_RERANK_POOL_CAP=32
# RETRIEVAL_MAX_CHUNKS_PER_PAPER_PREFETCH=3
# RETRIEVAL_FINAL_MAX_PER_PAPER=2
# RETRIEVAL_METADATA_BOOST_CAP=0.08
# RETRIEVAL_USE_CORPUS_BM25=true
# RETRIEVAL_CORPUS_BM25_TOP_K=50
# RETRIEVAL_USE_HYDE=true
# RETRIEVAL_HYDE_MAX_TOKENS=6
# RETRIEVAL_HYDE_MAX_CHARS=48
# RETRIEVAL_USE_TECHNICAL_EXPANSION=false

# Hugging Face token for faster reranker model pulls (optional)
# HF_TOKEN=
